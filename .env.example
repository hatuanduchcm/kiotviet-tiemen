# KiotViet
KIOTVIET_BASE_URL=https://hatuanduc.kiotviet.vn
KIOTVIET_USERNAME=0972989514
KIOTVIET_PASSWORD=Hatuanduc@

# Browser
HEADLESS=true
SLOW_MO_MS=0
TIMEOUT_MS=45000

# If you want to visually verify login in headed mode
STOP_AFTER_LOGIN=false
STOP_AFTER_LOGIN_MS=60000

# Debug (useful for headless runs)
TRACE=false
TRACE_PATH=.storage/trace.zip

# Orders watch (poll Orders page)
# Optional: you can omit this and the app will use `${KIOTVIET_BASE_URL}/man/#/Orders`.
# Short forms are accepted: Orders | /Orders | #/Orders | /man/#/Orders
ORDERS_URL=/Orders
ORDERS_TIME_PRESET=Tuần này
ORDERS_POLL_INTERVAL_MS=60000

# Stop conditions (0 = unlimited)
ORDERS_MAX_POLLS=0
ORDERS_MAX_RUN_MS=0
ORDERS_MAX_CONSECUTIVE_ERRORS=0

# (Optional) Export tuning
ORDERS_EXPORT_TIMEOUT_MS=30000

# Cleanup
ORDERS_DELETE_DOWNLOADED_AFTER_UPLOAD=true

# (Optional) Debug: export some existing orders on first run to validate selection/download.
ORDERS_DEBUG_EXPORT_EXISTING=false
ORDERS_DEBUG_MAX_EXPORT=1

# Google Sheets
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB_NAME=OrderData
GOOGLE_SHEET_TAB_NAME_RAW=OrderDataRaw
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=
