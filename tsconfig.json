{
  "compilerOptions": {
    "target": "ES2022",
  "lib": ["ES2022", "DOM"],
  "module": "Node16",
  "moduleResolution": "node16",
  "allowJs": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "outDir": "dist"
  },
  "include": ["src/**/*"]
}
